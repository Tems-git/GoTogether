{
  "expo": {
    "name": "GoTogether",
    "slug": "gotogether",
    "version": "1.0.0",
    "scheme": "gotogether",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.temsit.gotogether",
      "infoPlist": {
        "NSCameraUsageDescription": "GoTogether използва камерата за снимане на документи.",
        "NSPhotoLibraryUsageDescription": "GoTogether използва галерията за качване на документи и снимки.",
        "NSPhotoLibraryAddUsageDescription": "GoTogether запазва снимки в галерията."
      }
    },
    "android": {
      "package": "com.temsit.gotogether",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "GoTogether използва галерията за качване на документи и снимки.",
          "cameraPermission": "GoTogether използва камерата за снимане на документи."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ce8969c9-88b7-42cb-838f-d3849a88cbcc"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/ce8969c9-88b7-42cb-838f-d3849a88cbcc"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
